    {"id": "chain-10", "user_goal": "Batch URL ingest then cross-analysis", "sequence": ["notebook_create", "fleet_ingest_url", "fleet_ingest_url", "fleet_ingest_url", "notebook_query"]},
    {"id": "error-1", "user_goal": "Auth failure recovery", "note": "Run nlm_doctor; user must run 'nlm login' in terminal"},
    {"id": "error-2", "user_goal": "nlm CLI missing recovery", "note": "Install with 'uv tool install notebooklm-mcp-cli'"},
    {"id": "error-3", "user_goal": "Tool timeout recovery", "note": "Retry with shorter timeout; increase QUERY_TIMEOUT_SECONDS env var"},
    {"id": "error-4", "user_goal": "Notebook not found", "note": "Run notebook_list to find valid IDs"},
    {"id": "error-5", "user_goal": "Source processing still pending", "note": "Set wait=False and poll source_list until source appears"},
    {"id": "error-6", "user_goal": "Studio artifact not ready", "note": "Check studio_status for processing status; artifacts take 30-120s"},
    {"id": "error-7", "user_goal": "Port conflict on startup", "note": "Run stop.bat to free ports, then restart"},
    {"id": "error-8", "user_goal": "Pipeline partially failed", "note": "Notebook may be created. Check with notebook_list and re-run research separately"},
    {"id": "dash-1", "user_goal": "Open glass dashboard UI", "note": "Run .\\start.ps1 then open http://127.0.0.1:10784"},
    {"id": "dash-2", "user_goal": "Check backend health via browser", "note": "Open http://127.0.0.1:10783/api/health"},
    {"id": "dash-3", "user_goal": "View tool manifest", "note": "GET http://127.0.0.1:10783/api/tools"},
    {"id": "dash-4", "user_goal": "View fleet discovery list", "note": "GET http://127.0.0.1:10783/api/fleet"},
    {"id": "dash-5", "user_goal": "View Swagger API docs", "note": "Open http://127.0.0.1:10783/docs"},
    {"id": "http-1", "user_goal": "Call MCP over HTTP", "note": "POST http://127.0.0.1:10783/mcp with MCP JSON-RPC body"},
    {"id": "http-2", "user_goal": "List MCP tools via HTTP", "note": "POST {\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"} to http://127.0.0.1:10783/mcp"},
    {"id": "http-3", "user_goal": "Call notebook_list via HTTP", "note": "POST {\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"notebook_list\",\"arguments\":{}}} to http://127.0.0.1:10783/mcp"},
    {"id": "stdio-1", "user_goal": "Run server in stdio mode for Claude Desktop", "note": "uv run python -m notebooklm_fleet_mcp --stdio"},
    {"id": "stdio-2", "user_goal": "Run server in HTTP mode for dashboard", "note": "uv run python -m notebooklm_fleet_mcp --serve"},
    {"id": "skill-1", "user_goal": "Follow bundled notebooklm-fleet skill", "note": "Read skill://notebooklm-fleet via MCP resources"},
    {"id": "mcpb-1", "user_goal": "Build Claude Desktop MCPB bundle", "note": "uv sync && just mcpb-pack"},
    {"id": "mcpb-2", "user_goal": "Validate MCPB bundle", "note": "mcpb validate dist/notebooklm-fleet-mcp-v0.1.0.mcpb"},
    {"id": "mcpb-3", "user_goal": "Inspect MCPB bundle contents", "note": "mcpb inspect dist/notebooklm-fleet-mcp-v0.1.0.mcpb"},
    {"id": "install-1", "user_goal": "Install in Cursor", "note": "Run .\\install-mcp.ps1 cursor from repo root"},
    {"id": "install-2", "user_goal": "Set up nlm CLI", "note": "uv tool install notebooklm-mcp-cli"},
    {"id": "install-3", "user_goal": "Authenticate nlm", "note": "nlm login"},
    {"id": "install-4", "user_goal": "Verify installation", "note": "nlm doctor"},
    {"id": "install-5", "user_goal": "Add nlm to PATH", "note": "$env:PATH += \";$env:USERPROFILE\\.local\\bin\""},
    {"id": "fleet-1", "user_goal": "Check fleet integration health", "note": "Run pipeline_liveness"},
    {"id": "fleet-2", "user_goal": "Discover other fleet apps", "note": "GET /api/fleet from the dashboard"},
    {"id": "fleet-3", "user_goal": "Start from Fleet Starts UI", "note": "Open http://127.0.0.1:10791 from mcp-central-docs"},
    {"id": "rest-1", "user_goal": "Create notebook via REST API", "note": "POST /api/notebooks {\"title\": \"Test\"} to port 10783"},
    {"id": "rest-2", "user_goal": "Query notebook via REST API", "note": "POST /api/notebooks/{id}/query {\"question\": \"Summarize\"} to port 10783"},
    {"id": "rest-3", "user_goal": "Start research via REST API", "note": "POST /api/notebooks/{id}/research {\"query\": \"topic\", \"mode\": \"fast\"} to port 10783"},
    {"id": "rest-4", "user_goal": "Run fleet pipeline via REST API", "note": "POST /api/fleet/pipeline/research {\"title\": \"X\", \"query\": \"Y\"} to port 10783"},
    {"id": "rest-5", "user_goal": "Ingest arXiv via REST API", "note": "POST /api/fleet/ingest/arxiv?notebook_id={id} {\"paper_id\": \"2401.00001\"} to port 10783"},
    {"id": "env-1", "user_goal": "Configure custom port", "note": "Set NOTEBOOKLM_FLEET_MCP_PORT env var"},
    {"id": "env-2", "user_goal": "Configure custom nlm path", "note": "Set NOTEBOOKLM_FLEET_MCP_NLM_PATH env var"},
    {"id": "env-3", "user_goal": "Increase query timeout", "note": "Set NOTEBOOKLM_FLEET_MCP_QUERY_TIMEOUT_SECONDS=300"},
    {"id": "env-4", "user_goal": "Point to alternative arxiv-mcp", "note": "Set NOTEBOOKLM_FLEET_MCP_ARXIV_MCP_BASE env var"},
    {"id": "env-5", "user_goal": "Run in Tauri mode", "note": "Set NOTEBOOKLM_FLEET_MCP_TAURI=1 for CORS relaxation"}
  ]
}
