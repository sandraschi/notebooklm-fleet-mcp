    {"id": "fleet-arxiv-2", "user_goal": "Ingest arXiv paper with tag", "tools": ["fleet_ingest_arxiv"], "args_hint": {"notebook_id": "...", "paper_id": "2401.00002", "tag": "arxiv:cs.LG"}},
