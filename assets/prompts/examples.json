{
  "version": "1.0",
  "description": "Structured tool-usage examples for notebooklm-fleet-mcp (expand toward 100+ for full SOTA bar).",
  "examples": [
    {"id": "health-1", "user_goal": "Check auth before work", "tools": ["nlm_doctor"], "args_hint": {}},
    {"id": "health-2", "user_goal": "Supervisor liveness probe", "tools": ["pipeline_liveness"], "args_hint": {}},
    {"id": "help-1", "user_goal": "Package overview", "tools": ["notebooklm_fleet_help"], "args_hint": {}},
    {"id": "help-2", "user_goal": "List help topics", "tools": ["notebooklm_help_topics"], "args_hint": {}},
    {"id": "help-3", "user_goal": "Read fleet integration help", "tools": ["notebooklm_help"], "args_hint": {"topic": "fleet"}},
    {"id": "nb-list-1", "user_goal": "List all notebooks", "tools": ["notebook_list"], "args_hint": {}},
    {"id": "nb-create-1", "user_goal": "Create notebook", "tools": ["notebook_create"], "args_hint": {"title": "Q2 Research"}},
    {"id": "nb-query-1", "user_goal": "Ask grounded question", "tools": ["notebook_query"], "args_hint": {"notebook_id": "...", "question": "Summarize key disagreements"}},
    {"id": "src-list-1", "user_goal": "Audit sources", "tools": ["source_list"], "args_hint": {"notebook_id": "..."}},
    {"id": "src-url-1", "user_goal": "Add URL source", "tools": ["source_add_url"], "args_hint": {"notebook_id": "...", "url": "https://example.com/paper", "wait": false}},
    {"id": "src-text-1", "user_goal": "Paste notes", "tools": ["source_add_text"], "args_hint": {"notebook_id": "...", "text": "# Notes", "title": "Meeting notes"}},
    {"id": "studio-1", "user_goal": "List artifacts", "tools": ["studio_status"], "args_hint": {"notebook_id": "..."}},
    {"id": "audio-1", "user_goal": "Deep dive podcast", "tools": ["audio_create"], "args_hint": {"notebook_id": "...", "format": "deep_dive", "length": "default"}},
    {"id": "slides-1", "user_goal": "Detailed deck", "tools": ["slides_create"], "args_hint": {"notebook_id": "...", "format": "detailed_deck"}},
    {"id": "slides-rev-1", "user_goal": "Enlarge title slide", "tools": ["slides_revise"], "args_hint": {"artifact_id": "...", "slide_instruction": "1 Make the title larger"}},
    {"id": "research-1", "user_goal": "Fast web research", "tools": ["research_start"], "args_hint": {"query": "MCP server patterns 2025", "mode": "fast", "source": "web"}},
    {"id": "research-2", "user_goal": "Deep research into existing nb", "tools": ["research_start"], "args_hint": {"query": "...", "notebook_id": "...", "mode": "deep"}},
    {"id": "tag-list-1", "user_goal": "See tags", "tools": ["tag_list"], "args_hint": {}},
    {"id": "tag-add-1", "user_goal": "Tag notebook", "tools": ["tag_add"], "args_hint": {"notebook_id": "...", "tags": "fleet,review"}},
    {"id": "fleet-arxiv-1", "user_goal": "Ingest arXiv paper", "tools": ["fleet_ingest_arxiv"], "args_hint": {"notebook_id": "...", "paper_id": "2401.00001", "wait": true}},
    {"id": "fleet-url-1", "user_goal": "Ingest with tag", "tools": ["fleet_ingest_url"], "args_hint": {"notebook_id": "...", "url": "https://...", "tag": "review"}},
    {"id": "fleet-repo-1", "user_goal": "Link fleet repo", "tools": ["fleet_link_repo"], "args_hint": {"notebook_id": "...", "repo_id": "arxiv-mcp"}},
    {"id": "fleet-pipe-1", "user_goal": "Full research pipeline", "tools": ["fleet_pipeline_research"], "args_hint": {"title": "Scaling Laws", "query": "Chinchilla follow-ups", "mode": "fast", "create_slides": true, "repo_id": "arxiv-mcp"}},
    {"id": "chain-1", "user_goal": "Create then query", "sequence": ["notebook_create", "source_add_url", "notebook_query"]},
    {"id": "chain-2", "user_goal": "Research then slides", "sequence": ["fleet_pipeline_research", "studio_status", "slides_revise"]},
    {"id": "chain-3", "user_goal": "arXiv ingest then audio", "sequence": ["fleet_ingest_arxiv", "audio_create"]},
    {"id": "error-1", "user_goal": "Auth failure", "note": "Run nlm_doctor; user must nlm login"},
    {"id": "error-2", "user_goal": "nlm missing", "note": "uv tool install notebooklm-mcp-cli"},
    {"id": "dash-1", "user_goal": "Open glass UI", "note": "start.ps1 → http://127.0.0.1:10784"},
    {"id": "http-1", "user_goal": "MCP over HTTP", "note": "POST http://127.0.0.1:10783/mcp"},
    {"id": "stdio-1", "user_goal": "Cursor stdio", "note": "uv run python -m notebooklm_fleet_mcp --stdio"},
    {"id": "skill-1", "user_goal": "Follow bundled skill", "note": "skill://notebooklm-fleet"},
    {"id": "mcpb-1", "user_goal": "Claude Desktop bundle", "note": "just mcpb-pack after uv sync"}
  ]
}
